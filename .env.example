# Coolify environment variables for the coolify-ssl resource.
# See docker-compose.example.yml / docker-compose.coolify.yml and SECURITY.md.

# Base name of emitted files (lan.cert / lan.key). Must match Traefik's provider.
# Allowed charset: A-Za-z0-9._-
CERT_NAME=lan

# Poll interval between renewal/sync checks (default: 2592000 = 30 days).
# Minimum: 60. Maximum: 315360000 (≈ 10 years). Sleep uses ≤60s chunks so SIGTERM
# stays responsive without 1Hz wakeups.
CHECK_INTERVAL_SECONDS=2592000

# Re-issue when the leaf expires within this many seconds (default: 2592000).
# Also re-issues on SAN drift or missing/mismatched leaf material.
RENEW_BEFORE_EXPIRY_SECONDS=2592000

# Legacy alias: when CHECK_INTERVAL_SECONDS / RENEW_BEFORE_EXPIRY_SECONDS are unset,
# this single value fills both (same default 2592000). Prefer the dedicated vars above.
# RENEW_INTERVAL_SECONDS=2592000

# Maximum number of SANs accepted from SSL_DOMAINS / domains.txt (default: 64).
# MAX_DOMAINS=64

# Domains separated by spaces, commas, or newlines (DNS labels, *.a.b wildcards, IPv4, IPv6).
# Ignored when a non-empty File Mount exists at /etc/ssl-gen/domains.txt.
# SAN matching canonicalizes IPv6/IPv4 and DNS case (no renew loop on textual form).
SSL_DOMAINS=app.example.lan,grafana.example.lan,*.tools.example.lan

# --- Optional SSH leaf sync (never the CA) ---
# Hosts that terminate their own TLS (spaces or commas). Empty = local only.
# Hostname or IPv4 only (IPv6 sync peers are not supported).
# Each check cycle: sync unless remote leaf DER SHA-256 already matches (needs openssl on peer).
# Default SSH user is root (Coolify convention). Prefer a dedicated account:
# see docs/ssh-least-privilege.md
CERT_SYNC_HOSTS=
CERT_SYNC_SSH_USER=root
CERT_SYNC_SSH_PORT=22

# Abort the process if any sync target fails (default: 1). Set 0 to warn and continue.
CERT_SYNC_STRICT=1

# Seconds to sleep before exiting when CERT_SYNC_STRICT aborts (default: 60).
# Avoids Docker restart storms against peers. Set 0 to disable (tests).
# CERT_SYNC_FAIL_BACKOFF_SECONDS=60

REMOTE_CERT_DIR=/data/coolify/proxy/certs
REMOTE_DYNAMIC_DIR=/data/coolify/proxy/dynamic

# Container path of the single bind-mounted Coolify SSH key (preferred).
# Compose: mount ONE file, not the whole keys directory, e.g.
#   /data/coolify/ssh/keys/ssh_key@<uuid>:/run/coolify-ssl/sync.key:ro
CERT_SYNC_SSH_KEY_PATH=/run/coolify-ssl/sync.key

# Persisted OpenSSH known_hosts (StrictHostKeyChecking=yes). Default lives on the CA volume.
# Seed before enabling sync, e.g.:
#   ssh-keyscan -H 10.0.0.5 >> /data/coolify/ca/ssh_known_hosts
# Leave unset to use the default /caroot/ssh_known_hosts.
# SSH_KNOWN_HOSTS_FILE=/caroot/ssh_known_hosts

# Exclusive writer lock (flock). Default: $CERT_DIR/.coolify-ssl.lock
# A second coolify-ssl on the same cert volume exits immediately.
# LOCK_FILE=/certs/.coolify-ssl.lock

# mkcert -install trust-store targets. Default java avoids system/NSS mutation;
# CA files still land in /caroot. Override only if you want host install.
# TRUST_STORES=java
